# Ignore everything in this repository (keeps only .gitignore tracked)
/*
!.gitignore
# --- Ignore all Python cache files ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.py
git add -f my_special_script.py


# --- Ignore virtual environments ---
venv/
env/
.venv/
.env/

# --- Ignore editor settings ---
.vscode/
.idea/

# --- Ignore logs and temp files ---
*.log
*.tmp
*.temp

# --- Ignore Jupyter Notebook checkpoints ---
.ipynb_checkpoints/

# --- Ignore packaging/build artifacts ---
build/
dist/
*.egg-info/

# --- Ignore environment variable files ---
*.env
.env.*

# --- Ignore OS-specific clutter ---
.DS_Store
Thumbs.db


# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
*.egg
pip-wheel-metadata/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
.tox/
*.coverage
*.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# pipenv
Pipfile.lock

# poetry
poetry.lock

# virtualenv
venv/
ENV/
env/
.env
.venv
myenv/

# Spyder project settings
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/

# VS Code
.vscode/

# JetBrains
.idea/

# System files
.DS_Store
Thumbs.db

# Frontend
node_modules/
dist/
